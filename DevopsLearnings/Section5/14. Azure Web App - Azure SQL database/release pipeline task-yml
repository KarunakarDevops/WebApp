steps:
- task: SqlAzureDacpacDeployment@1
  displayName: 'Run SQL Inline script'
  inputs:
    azureSubscription: 'My Visual Studio Professional Subscription(449214d1-cece-42d9-9bec-e11ecea9f162)'
    ServerName: demodbserverkaruna.database.windows.net
    DatabaseName: 'demo-db'
    SqlUsername: sqladmin
    SqlPassword: 'LearnAzure@2026'
    deployType: InlineSqlTask
    SqlInline: |
     GO
     IF (NOT EXISTS (SELECT * FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA ='dbo' AND TABLE_NAME ='Products'))
     BEGIN
     
     CREATE TABLE Products
     (
          ProductID int,
          ProductName varchar(1000),
          Quantity int
     )
      
      
     INSERT INTO Products(ProductID,ProductName,Quantity) VALUES (1,'Mobile',100)
      
     INSERT INTO Products(ProductID,ProductName,Quantity) VALUES (2,'Laptop',200)
      
     INSERT INTO Products(ProductID,ProductName,Quantity) VALUES (3,'Tabs',300)
     
     END
    IpDetectionMethod: IPAddressRange
    StartIpAddress: 0.0.0.0
    EndIpAddress: 0.0.0.0
    DeleteFirewallRule: false

